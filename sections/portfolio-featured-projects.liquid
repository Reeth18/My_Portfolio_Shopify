{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="portfolio-featured-projects"
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="{% if section.settings.full_width == false %}page-width{% endif %}">
    <div class="collection section-{{ section.id }}-padding" id="portfolio-projects-{{ section.id }}">
      {%- if section.settings.heading != blank -%}
        <div class="portfolio-featured-projects__header">
          <h2 class="portfolio-featured-projects__heading {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div
          class="portfolio-featured-projects__slider"
          id="PortfolioSlider-{{ section.id }}"
          data-section-id="{{ section.id }}"
        >
          {%- for block in section.blocks -%}
            <div class="portfolio-featured-projects__slide" {{ block.shopify_attributes }}>
              <div class="portfolio-project-card">
                <a
                  href="{{ block.settings.project_link }}"
                  class="portfolio-project-card__link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <div class="portfolio-project-card__media">
                    {%- if block.settings.image != blank -%}
                      <img
                        srcset="
                          {%- if block.settings.image.width >= 165 -%}{{ block.settings.image | image_url: width: 165 }} 165w,{%- endif -%}
                          {%- if block.settings.image.width >= 360 -%}{{ block.settings.image | image_url: width: 360 }} 360w,{%- endif -%}
                          {%- if block.settings.image.width >= 533 -%}{{ block.settings.image | image_url: width: 533 }} 533w,{%- endif -%}
                          {%- if block.settings.image.width >= 720 -%}{{ block.settings.image | image_url: width: 720 }} 720w,{%- endif -%}
                          {{ block.settings.image | image_url }} {{ block.settings.image.width }}w
                        "
                        src="{{ block.settings.image | image_url: width: 533 }}"
                        sizes="(min-width: 1200px) calc((1200px - 6rem) / 3), (min-width: 750px) calc((100vw - 6rem) / 2), calc(100vw - 3rem)"
                        alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                        class="portfolio-project-card__image"
                        {% if forloop.index > 3 %}
                          loading="lazy"
                        {% endif %}
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                      >
                    {%- else -%}
                      <div class="portfolio-project-card__placeholder">
                        {{ 'product-apparel-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                  </div>
                  <div class="portfolio-project-card__content">
                    {%- if block.settings.title != blank -%}
                      <h3 class="portfolio-project-card__title">{{ block.settings.title | escape }}</h3>
                    {%- endif -%}
                    {%- if block.settings.description != blank -%}
                      <p class="portfolio-project-card__description">{{ block.settings.description }}</p>
                    {%- endif -%}
                    <span class="portfolio-project-card__button">View Project</span>
                  </div>
                </a>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="portfolio-featured-projects__slider" id="PortfolioSlider-{{ section.id }}">
          {%- for i in (1..4) -%}
            <div class="portfolio-featured-projects__slide">
              <div class="portfolio-project-card">
                <div class="portfolio-project-card__link">
                  <div class="portfolio-project-card__media">
                    <div class="portfolio-project-card__placeholder">
                      {{ 'product-apparel-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  </div>
                  <div class="portfolio-project-card__content">
                    <h3 class="portfolio-project-card__title">Project {{ i }}</h3>
                    <p class="portfolio-project-card__description">
                      Add your project description here to showcase your work.
                    </p>
                    <span class="portfolio-project-card__button">View Project</span>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick.css"/>
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick-theme.css"/>

<style>
  /* =============================================
     Portfolio Featured Projects — Section Styles
     ============================================= */

  /* Header */
  .portfolio-featured-projects__header {
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .portfolio-featured-projects__heading {
    color: #1a1a1a;
    font-weight: 700;
  }

  /* Slider wrapper */
  .portfolio-featured-projects__slider {
    padding: 1rem 0 2rem;
  }

  .portfolio-featured-projects__slider .slick-list {
    overflow: visible;
    margin: 0 -0.75rem;
  }

  .portfolio-featured-projects__slide {
    padding: 0 0.75rem;
    box-sizing: border-box;
    outline: none;
  }

  /* Project card */
  .portfolio-featured-projects .portfolio-project-card {
    border-radius: 1rem;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
  }

  .portfolio-featured-projects .portfolio-project-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
  }

  .portfolio-featured-projects .portfolio-project-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* Card image */
  .portfolio-featured-projects .portfolio-project-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: #f5f5f5;
  }

  .portfolio-featured-projects .portfolio-project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .portfolio-featured-projects .portfolio-project-card:hover .portfolio-project-card__image {
    transform: scale(1.05);
  }

  .portfolio-featured-projects .portfolio-project-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
  }

  .portfolio-featured-projects .portfolio-project-card__placeholder .placeholder-svg {
    width: 60%;
    opacity: 0.4;
  }

  /* Card content */
  .portfolio-featured-projects .portfolio-project-card__content {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .portfolio-featured-projects .portfolio-project-card__title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .portfolio-featured-projects .portfolio-project-card__description {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.5;
    margin: 0 0 1rem;
    flex-grow: 1;
  }

  /* View Project button */
  .portfolio-featured-projects .portfolio-project-card__button {
    display: inline-block;
    align-self: flex-start;
    padding: 0.625rem 1.5rem;
    background: #ff7a00;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.3s ease, transform 0.2s ease;
    letter-spacing: 0.02em;
  }

  .portfolio-featured-projects .portfolio-project-card:hover .portfolio-project-card__button {
    background: #e66d00;
    transform: translateX(4px);
  }

  /* Slick arrow overrides */
  .portfolio-featured-projects .slick-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid #ff7a00;
    background: #fff;
    color: #ff7a00;
    display: flex !important;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    font-size: 0;
    line-height: 0;
    padding: 0;
  }

  .portfolio-featured-projects .slick-arrow:hover {
    background: #ff7a00;
    color: #fff;
  }

  .portfolio-featured-projects .slick-arrow:before {
    font-size: 18px;
    line-height: 1;
    color: inherit;
    font-family: inherit;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .portfolio-featured-projects .slick-prev {
    left: -8px;
  }

  .portfolio-featured-projects .slick-prev:before {
    content: '\2039';
    font-size: 24px;
    font-weight: 700;
  }

  .portfolio-featured-projects .slick-next {
    right: -8px;
  }

  .portfolio-featured-projects .slick-next:before {
    content: '\203A';
    font-size: 24px;
    font-weight: 700;
  }

  .portfolio-featured-projects .slick-disabled {
    opacity: 0.35;
    cursor: default;
  }

  /* Slick dots */
  .portfolio-featured-projects .slick-dots {
    display: flex !important;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }

  .portfolio-featured-projects .slick-dots li {
    margin: 0;
    padding: 0;
    width: auto;
    height: auto;
  }

  .portfolio-featured-projects .slick-dots li button {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ccc;
    border: none;
    padding: 0;
    font-size: 0;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.2s ease;
  }

  .portfolio-featured-projects .slick-dots li.slick-active button {
    background: #ff7a00;
    transform: scale(1.2);
  }

  .portfolio-featured-projects .slick-dots li button:hover {
    background: #ff7a00;
  }

  /* Equal height slides */
  .portfolio-featured-projects .slick-track {
    display: flex !important;
  }

  .portfolio-featured-projects .slick-slide {
    height: auto;
  }

  .portfolio-featured-projects .slick-slide > div {
    height: 100%;
  }

  .portfolio-featured-projects__slide {
    height: 100%;
  }

  /* ---- Tablet ---- */
  @media screen and (max-width: 989px) and (min-width: 750px) {
    .portfolio-featured-projects .slick-prev {
      left: -4px;
    }

    .portfolio-featured-projects .slick-next {
      right: -4px;
    }
  }

  /* ---- Mobile ---- */
  @media screen and (max-width: 749px) {
    .portfolio-featured-projects__slider .slick-list {
      margin: 0 -0.5rem;
      overflow: visible;
    }

    .portfolio-featured-projects__slide {
      padding: 0 0.5rem;
    }

    .portfolio-featured-projects .portfolio-project-card__content {
      padding: 1rem 1.25rem 1.25rem;
    }

    .portfolio-featured-projects .portfolio-project-card__title {
      font-size: 1rem;
    }

    .portfolio-featured-projects .slick-arrow {
      width: 36px;
      height: 36px;
    }

    .portfolio-featured-projects .slick-prev {
      left: 2px;
    }

    .portfolio-featured-projects .slick-next {
      right: 2px;
    }

    .portfolio-featured-projects .slick-dots {
      margin-top: 1rem;
    }
  }
</style>

<script src="https://code.jquery.com/jquery-4.0.0.js" integrity="sha256-9fsHeVnKBvqh3FB2HYu7g2xseAZ5MlN6Kz/qnkASV8U=" crossorigin="anonymous"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick.min.js"></script>

<script>
  (function () {
    function initPortfolioSlider() {
      var $slider = jQuery('#PortfolioSlider-{{ section.id }}');
      if ($slider.length) {
        if ($slider.hasClass('slick-initialized')) {
          $slider.slick('unslick');
        }
        $slider.slick({
          slidesToShow: 3,
          slidesToScroll: 1,
          arrows: true,
          dots: true,
          infinite: true,
          speed: 500,
          cssEase: 'ease',
          swipe: true,
          swipeToSlide: true,
          touchThreshold: 10,
          responsive: [
            {
              breakpoint: 990,
              settings: {
                slidesToShow: 2,
                slidesToScroll: 1
              }
            },
            {
              breakpoint: 750,
              settings: {
                slidesToShow: 1,
                slidesToScroll: 1,
                centerMode: true,
                centerPadding: '10%'
              }
            }
          ]
        });
      }
    }

    jQuery(document).ready(function () {
      initPortfolioSlider();
    });

    if (window.Shopify && Shopify.designMode) {
      document.addEventListener('shopify:section:load', function (event) {
        if (event.detail.sectionId === '{{ section.id }}') {
          initPortfolioSlider();
        }
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Portfolio Projects",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Featured Projects",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "color",
      "id": "background_color",
      "default": "#ffffff",
      "label": "Background color"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "Full width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "project",
      "name": "Project",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Project image"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Project Title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "default": "A brief description of this project and the technologies used.",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "project_link",
          "label": "Project link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Portfolio Featured Projects",
      "blocks": [{ "type": "project" }, { "type": "project" }, { "type": "project" }, { "type": "project" }]
    }
  ]
}
{% endschema %}
