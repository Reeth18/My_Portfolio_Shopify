{{ 'portfolio-hero-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="portfolio-hero page-width section-{{ section.id }}-padding">
    <div class="portfolio-hero__container portfolio-hero__align--{{ section.settings.text_alignment }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="portfolio-hero__content">
        {%- if section.settings.name != blank -%}
          <h1 class="portfolio-hero__heading">{{ section.settings.name }}</h1>
        {%- endif -%}

        {%- if section.settings.designation != blank -%}
          <p class="portfolio-hero__designation">{{ section.settings.designation }}</p>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="portfolio-hero__description">{{ section.settings.description }}</div>
        {%- endif -%}

        <div class="portfolio-hero__buttons">
          {%- if section.settings.button_1_label != blank -%}
            <a
              {% if section.settings.button_1_link %}
                href="{{ section.settings.button_1_link }}"
              {% else %}
                role="link" aria-disabled="true"
              {% endif %}
              class="button {% if section.settings.button_1_secondary %}button--secondary{% else %}button--primary{% endif %}"
            >
              {{- section.settings.button_1_label | escape -}}
            </a>
          {%- endif -%}

          {%- if section.settings.button_2_label != blank -%}
            <a
              {% if section.settings.button_2_link %}
                href="{{ section.settings.button_2_link }}"
              {% else %}
                role="link" aria-disabled="true"
              {% endif %}
              class="button {% if section.settings.button_2_secondary %}button--secondary{% else %}button--primary{% endif %}"
            >
              {{- section.settings.button_2_label | escape -}}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="portfolio-hero__image-wrapper">
        {%- if section.settings.profile_image != blank -%}
          {%- liquid
            assign height = section.settings.profile_image.width | divided_by: section.settings.profile_image.aspect_ratio | round
            assign fetch_priority = 'auto'
            if section.index == 1
              assign fetch_priority = 'high'
            endif
          -%}
          {{
            section.settings.profile_image
            | image_url: width: 600
            | image_tag:
              height: height,
              sizes: '(max-width: 749px) 280px, 400px',
              widths: '300, 450, 600',
              fetchpriority: fetch_priority,
              class: 'portfolio-hero__image'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'portfolio-hero__image portfolio-hero__image--placeholder' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Portfolio Hero Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "John Doe"
    },
    {
      "type": "text",
      "id": "designation",
      "label": "Designation",
      "default": "Shopify Developer"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "I build clean, conversion-focused Shopify stores that help brands grow. From custom themes to seamless user experiences — I turn ideas into polished online storefronts."
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "profile_image",
      "label": "Profile Image"
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 Label",
      "default": "View Projects",
      "info": "Leave blank to hide button"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "checkbox",
      "id": "button_1_secondary",
      "label": "Use outline button style",
      "default": false
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 Label",
      "default": "Contact Me",
      "info": "Leave blank to hide button"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "checkbox",
      "id": "button_2_secondary",
      "label": "Use outline button style",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Portfolio Hero Banner"
    }
  ]
}
{% endschema %}
