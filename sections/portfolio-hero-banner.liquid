{{ 'portfolio-hero-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .portfolio-hero {
    background-color: {{ section.settings.background_color }};
  }
{%- endstyle -%}

<section class="portfolio-hero" id="section-{{ section.id }}">
  <div class="portfolio-hero__container portfolio-hero__align--{{ section.settings.text_alignment }}">
    <div class="portfolio-hero__content">
      {%- if section.settings.name != blank -%}
        <h1 class="portfolio-hero__heading">{{ section.settings.name }}</h1>
      {%- endif -%}

      {%- if section.settings.designation != blank -%}
        <p class="portfolio-hero__designation">{{ section.settings.designation }}</p>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="portfolio-hero__description">{{ section.settings.description }}</div>
      {%- endif -%}

      <div class="portfolio-hero__buttons">
        {%- if section.settings.button_1_label != blank -%}
          <a
            href="{{ section.settings.button_1_link }}"
            class="portfolio-hero__btn portfolio-hero__btn--primary"
          >
            {{- section.settings.button_1_label -}}
          </a>
        {%- endif -%}

        {%- if section.settings.button_2_label != blank -%}
          <a
            href="{{ section.settings.button_2_link }}"
            class="portfolio-hero__btn portfolio-hero__btn--secondary"
          >
            {{- section.settings.button_2_label -}}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="portfolio-hero__image-wrapper">
      {%- if section.settings.profile_image != blank -%}
        <img
          src="{{ section.settings.profile_image | image_url: width: 600 }}"
          srcset="
            {{ section.settings.profile_image | image_url: width: 300 }} 300w,
            {{ section.settings.profile_image | image_url: width: 450 }} 450w,
            {{ section.settings.profile_image | image_url: width: 600 }} 600w
          "
          sizes="(max-width: 768px) 280px, 400px"
          alt="{{ section.settings.profile_image.alt | default: section.settings.name }}"
          class="portfolio-hero__image"
          width="{{ section.settings.profile_image.width }}"
          height="{{ section.settings.profile_image.height }}"
          loading="eager"
        >
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'portfolio-hero__image portfolio-hero__image--placeholder' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Portfolio Hero Banner",
  "tag": "section",
  "class": "portfolio-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "John Doe"
    },
    {
      "type": "text",
      "id": "designation",
      "label": "Designation",
      "default": "Shopify Developer"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "I build clean, conversion-focused Shopify stores that help brands grow. From custom themes to seamless user experiences — I turn ideas into polished online storefronts."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 Label",
      "default": "View Projects"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 Label",
      "default": "Contact Me"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "profile_image",
      "label": "Profile Image"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#fff8f2"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Portfolio Hero Banner"
    }
  ]
}
{% endschema %}
